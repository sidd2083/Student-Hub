rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admin upload paths — open writes so no Google sign-in popup is needed in admin panel
    match /pyqs/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /notes/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    // Everything else requires Firebase Auth
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
