rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Content files (notes / PYQs) ─────────────────────────────────────────
    // Public read so students can view without signing in.
    // Write requires authentication, max 5 MB, images + PDF only.
    // NOTE: Admin SDK uploads (from the backend) bypass these rules entirely,
    //       so the admin upload flow is unaffected.
    match /notes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.+|application/pdf');
    }

    match /pyqs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.+|application/pdf');
    }

    // ── All other paths ───────────────────────────────────────────────────────
    // Requires authentication for both read and write.
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024;
    }
  }
}
