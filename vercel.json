{
  "buildCommand": "pnpm --filter @workspace/student-hub run build",
  "outputDirectory": "artifacts/student-hub/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
